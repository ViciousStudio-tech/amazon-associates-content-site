# Business 1 — Amazon Associates Content Site
# Copy this to .env and fill in your real values
# NEVER commit .env to GitHub

# ── AI APIs ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# Get from: console.anthropic.com → API Keys

# ── Amazon ──────────────────────────────────────────────────────
AMAZON_ASSOCIATE_TAG=yourtag-20
# Get from: affiliate-program.amazon.com → Account Settings

AMAZON_ACCESS_KEY=AKIA_YOUR_KEY_HERE
AMAZON_SECRET_KEY=YOUR_SECRET_HERE
# Get from: Associates dashboard → Tools → Product Advertising API

AMAZON_MARKETPLACE=www.amazon.com

# ── GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE
# Get from: github.com → Settings → Developer Settings → Personal Access Tokens
# Permissions needed: repo (full control)

GITHUB_REPO=yourusername/your-repo-name
# Format: username/reponame — must match exactly

GITHUB_BRANCH=main

# ── Email Alerts ─────────────────────────────────────────────────
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Get from: myaccount.google.com → Security → 2-Step Verification → App passwords
# 2FA must be enabled first

GMAIL_TO=you@gmail.com

# ── Settings ─────────────────────────────────────────────────────
DB_PATH=./data/business1.db
ARTICLES_PER_RUN=15
